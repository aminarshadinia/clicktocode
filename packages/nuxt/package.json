{
  "name": "@clicktocode/nuxt",
  "version": "0.3.2",
  "description": "Click an element in your running Nuxt 3 app and hand it to a coding agent \u2014 element picker + OpenCode bridge.",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "vue",
    "devtools",
    "element-picker",
    "coding-agent",
    "opencode",
    "ai"
  ],
  "license": "MIT",
  "author": "Amin Arshadinia <Amin.Arshadinia@gmail.com> (https://github.com/aminarshadinia)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aminarshadinia/clicktocode.git",
    "directory": "packages/nuxt"
  },
  "homepage": "https://github.com/aminarshadinia/clicktocode/tree/main/packages/nuxt#readme",
  "bugs": "https://github.com/aminarshadinia/clicktocode/issues",
  "type": "module",
  "main": "./dist/module.js",
  "types": "./dist/module.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/module.d.ts",
        "default": "./dist/module.js"
      },
      "require": {
        "types": "./dist/module.d.cts",
        "default": "./dist/module.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clicktocode/core": "workspace:^",
    "@clicktocode/vue": "workspace:^",
    "@nuxt/kit": "^3.13.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
