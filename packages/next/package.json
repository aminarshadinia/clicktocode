{
  "name": "@clicktocode/next",
  "version": "0.3.1",
  "sideEffects": false,
  "description": "Click an element in your running Next.js app and hand it to a coding agent \u2014 element picker + OpenCode bridge. App Router and Pages Router.",
  "keywords": [
    "next",
    "nextjs",
    "react",
    "devtools",
    "element-picker",
    "coding-agent",
    "opencode",
    "ai"
  ],
  "license": "MIT",
  "author": "Amin Arshadinia <Amin.Arshadinia@gmail.com> (https://github.com/aminarshadinia)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aminarshadinia/clicktocode.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/aminarshadinia/clicktocode/tree/main/packages/next#readme",
  "bugs": "https://github.com/aminarshadinia/clicktocode/issues",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./instrumentation": {
      "import": {
        "types": "./dist/instrumentation.d.ts",
        "default": "./dist/instrumentation.js"
      },
      "require": {
        "types": "./dist/instrumentation.d.cts",
        "default": "./dist/instrumentation.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clicktocode/core": "workspace:^",
    "@clicktocode/react": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.1"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
